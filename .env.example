# Proxmox Configuration Example
# Copy this file to .env and fill with your actual values

# Proxmox API Settings
PROXMOX_API_HOST=192.168.1.100
PROXMOX_API_USER=root@pam
PROXMOX_API_TOKEN_ID=ttdaiu
PROXMOX_API_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_NODE=pve

# VM Template Settings
TEMPLATE_ID_NOBLE=8000
TEMPLATE_ID_JAMMY=8001

# Default VM Configuration
VM_CORES=2
VM_MEMORY=4096
VM_DISK_SIZE=20G
VM_STORAGE=local-lvm
VM_NETWORK_BRIDGE=vmbr0

# Cloud-init Settings
VM_USER=ubuntu
VM_SSH_KEYS_FILE=~/.ssh/id_rsa.pub

# Optional: Override defaults
# VM_ID=9000
# VM_NAME_PREFIX=ttdaiu